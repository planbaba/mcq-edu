---
import BaseLayout from './BaseLayout.astro';
interface Props { title: string; kicker?: string; }
const { title, kicker = 'Learning Dashboard' } = Astro.props;
---
<BaseLayout title={title}>
  <section class="comic-card bg-mintpop p-6 md:p-8 mb-8">
    <p class="sticker mb-3">{kicker}</p>
    <h1 class="text-4xl md:text-6xl font-black tracking-tight">{title}</h1>
  </section>
  <slot />
</BaseLayout>
