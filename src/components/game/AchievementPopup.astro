---
interface Props { title: string; detail: string; }
const { title, detail } = Astro.props;
---
<aside class="comic-card bg-sunshine p-5" aria-label="Achievement unlocked"><p class="sticker mb-2">Achievement Unlocked</p><h3 class="text-2xl font-black">🏅 {title}</h3><p class="font-bold">{detail}</p></aside>
