---
const links = [
  ['Home', '/'], ['Subjects', '/#subjects'], ['Map', '/map'], ['Leaderboard', '/leaderboard'], ['Notes', '/notes/fractions'], ['Videos', '/videos/fractions-video'], ['Progress', '/progress']
];
---
<header class="sticky top-0 z-40 border-b-5 border-ink bg-paper/95 backdrop-blur">
  <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:m-3 focus:rounded-xl focus:bg-sunshine focus:p-3 focus:font-black">Skip to content</a>
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-2 text-xl font-black"><span class="grid h-11 w-11 place-items-center rounded-2xl border-3 border-ink bg-bubblegum shadow-brut-sm">🎒</span> MCQ Adventure</a>
    <div class="hidden items-center gap-2 lg:flex">
      {links.map(([label, href]) => <a class="rounded-xl px-3 py-2 font-black hover:bg-sunshine" href={href}>{label}</a>)}
    </div>
  </nav>
</header>
