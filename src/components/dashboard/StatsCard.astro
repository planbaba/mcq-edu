---
interface Props { label: string; value: string; icon: string; color?: string; }
const { label, value, icon, color = 'bg-white' } = Astro.props;
---
<article class={`comic-card ${color} p-5`}><div class="text-4xl">{icon}</div><p class="mt-3 text-lg font-black">{label}</p><strong class="text-4xl font-black">{value}</strong></article>
