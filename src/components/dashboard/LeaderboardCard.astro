---
interface Props { rank: number; name: string; avatar: string; xp: number; stars: number; }
const { rank, name, avatar, xp, stars } = Astro.props;
---
<li class="comic-card flex items-center gap-4 bg-white p-4"><span class="grid h-12 w-12 place-items-center rounded-full border-3 border-ink bg-sunshine text-xl font-black">#{rank}</span><span class="text-4xl">{avatar}</span><div class="flex-1"><h3 class="text-2xl font-black">{name}</h3><p class="font-bold">{xp} XP · {stars} ⭐</p></div></li>
