---
interface Props { title: string; slug: string; duration: string; }
const { title, slug, duration } = Astro.props;
---
<a href={`/videos/${slug}`} class="comic-card block bg-bubblegum p-5"><p class="sticker mb-3">Video · {duration}</p><h3 class="text-2xl font-black">{title}</h3><p class="mt-2 font-bold">Watch the tutorial mission.</p></a>
