---
import { colorClasses, iconEmoji } from '../../lib/utils';
interface Props { title: string; slug: string; icon: string; color: string; description: string; progress?: number; }
const { title, slug, icon, color, description, progress = 25 } = Astro.props;
---
<a href={`/subjects/${slug}`} class={`comic-card block p-5 ${colorClasses[color] ?? 'bg-white'} transition hover:-translate-y-1`}>
  <div class="mb-4 flex items-start justify-between gap-3"><span class="text-5xl" aria-hidden="true">{iconEmoji[icon] ?? '✨'}</span><span class="sticker">{progress}% done</span></div>
  <h3 class="text-3xl font-black">{title}</h3>
  <p class="mt-2 text-lg font-bold">{description}</p>
  <div class="mt-4 h-4 rounded-full border-3 border-ink bg-white"><div class="h-full rounded-full bg-ink" style={`width:${progress}%`}></div></div>
</a>
