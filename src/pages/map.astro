---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { zones } from '../data/worldMap';
---
<DashboardLayout title="World Map" kicker="Adventure Map">
  <section class="comic-card relative overflow-hidden bg-skybolt p-6 md:p-10">
    <div class="absolute inset-0 opacity-20" aria-hidden="true">{Array.from({length:20}).map(() => <span class="m-8 inline-block text-4xl">✦</span>)}</div>
    <div class="relative grid gap-6 md:grid-cols-5">{zones.map((z, i) => <article class={`comic-card ${z.color} p-5 text-center ${i % 2 ? 'md:mt-24' : ''}`}><div class="text-6xl">{z.icon}</div><h2 class="mt-3 text-2xl font-black">{z.name}</h2><p class="sticker mt-3">{z.status}</p>{i < zones.length - 1 && <div class="mx-auto mt-5 h-3 w-24 rounded-full border-3 border-ink bg-white md:rotate-12" aria-hidden="true"></div>}</article>)}</div>
  </section>
</DashboardLayout>
